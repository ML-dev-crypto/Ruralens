{
  "name": "ruralens-backend",
  "version": "1.0.0",
  "description": "Backend server for RuraLens with GNN integration",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "clear-db": "node clearDB.js",
    "cleanup-feedback": "node cleanupFeedback.js",
    "export-pathway": "node scripts/export-to-pathway.js",
    "pathway-server": "cd python-gnn && python pathway_api_server.py"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@huggingface/inference": "^4.13.4",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "ollama": "^0.5.0",
    "pdf-parse-new": "^1.4.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
